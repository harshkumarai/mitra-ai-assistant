# Rename this file to .env and fill in your values.
# Never commit .env to version control.

# --- Porcupine wake-word detection (optional but recommended) ---
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here
PORCUPINE_KEYWORD_PATH=path/to/hey-assistant_mac.ppn

# --- OpenAI (optional — used for fallback NLU) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- OpenWeatherMap (for weather commands) ---
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# --- ElevenLabs Text-to-Speech (required for voice output) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=auq43ws1oslv0tO4BDa7
